# Copy to .env.local for local development: cp .env.example .env.local
# Full reference: documentation/TSD/1.7. Environment & Configuration.md

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://linkz:linkz_dev@localhost:5432/linkz_db

# Keycloak OIDC (realm/client created via the admin console — see README)
KEYCLOAK_ISSUER=http://localhost:8080/realms/linkz
KEYCLOAK_CLIENT_ID=linkz-web
KEYCLOAK_CLIENT_SECRET=

# Auth.js — session cookie encryption. Generate: `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Seat price in cents (e.g. 1000 = SGD 10.00)
SEAT_PRICE_CENTS=1000

# AXS Checkout sandbox (obtain from the AXS developer portal — developer.svc.axsasia.com)
AXS_CLIENT_ID=TEST
AXS_MERCHANT_LINK_ID=TEST
AXS_API_KEY=TEST
AXS_API_SECRET=TEST
AXS_CHECKOUT_URL=http://localhost:4000
AXS_API_BASE_URL=http://localhost:4000

# Cron job authentication — protects GET /api/public/cron/cleanup-expired
# Leave unset to disable the manual cron endpoint (in-process timer still runs)
CRON_SECRET=

# Test backdoor (non-production only — see TSD/2.6). Leave unset to disable.
TEST_RESET_TOKEN=
